# Flood Resilience System Backend - Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="Flood Resilience System"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=["localhost","127.0.0.1"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =============================================================================
# DATABASE - PostgreSQL with PostGIS and pgvector
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flood_resilience
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# For sync operations (Alembic migrations)
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/flood_resilience

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_PREFIX=flood:cache:
REDIS_SESSION_PREFIX=flood:session:

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# STORAGE (S3-compatible / MinIO / Local)
# =============================================================================
STORAGE_BACKEND=local
# For local storage
STORAGE_LOCAL_PATH=./storage

# For S3/MinIO
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
STORAGE_S3_BUCKET=flood-resilience
STORAGE_S3_REGION=us-east-1

# =============================================================================
# EXTERNAL APIS
# =============================================================================
# Weather APIs
OPEN_METEO_API_URL=https://api.open-meteo.com
RAINVIEWER_API_URL=https://api.rainviewer.com

# AI/LLM Provider
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-vl-30b-a3b-thinking
LLM_FALLBACK_MODELS=["google/gemma-3-1b-it:free","mistralai/mistral-small-3.1-24b-instruct:free"]

# Embedding generation (optional - can use local model)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CHAT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_REPORT_REQUESTS_PER_MINUTE=5

# =============================================================================
# FILE UPLOAD
# =============================================================================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
ALLOWED_DATA_TYPES=["text/csv","application/json","application/geo+json"]
ALLOWED_DOCUMENT_TYPES=["application/pdf","text/plain","text/markdown"]

# =============================================================================
# OBSERVABILITY
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=flood-resilience-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# SRI LANKA DEFAULTS
# =============================================================================
DEFAULT_LATITUDE=8.3593
DEFAULT_LONGITUDE=80.5103
DEFAULT_TIMEZONE=Asia/Colombo
COUNTRY_CODE=LK

# =============================================================================
# ADMIN SEED (for local development only)
# =============================================================================
SEED_ADMIN_EMAIL=admin@floodresilience.lk
SEED_ADMIN_PASSWORD=AdminPass123!
SEED_ADMIN_NAME=System Administrator
